<!DOCTYPE html>

<html class="light" lang="vi"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "outline": "#717786",
              "primary": "#0058bc",
              "surface-tint": "#005bc1",
              "surface-container": "#eeeef0",
              "on-error-container": "#93000a",
              "surface-dim": "#d9dadc",
              "secondary-fixed-dim": "#c7c6cb",
              "primary-container": "#0070eb",
              "secondary-fixed": "#e3e2e7",
              "on-secondary": "#ffffff",
              "on-primary-fixed": "#001a41",
              "on-primary": "#ffffff",
              "surface-container-lowest": "#ffffff",
              "error": "#ba1a1a",
              "on-tertiary": "#ffffff",
              "on-primary-container": "#fefcff",
              "on-surface": "#1a1c1d",
              "on-tertiary-fixed-variant": "#00531c",
              "surface-container-highest": "#e2e2e4",
              "secondary": "#5e5e63",
              "surface-bright": "#f9f9fb",
              "surface-variant": "#e2e2e4",
              "on-secondary-fixed": "#1a1b1f",
              "tertiary-fixed": "#72fe88",
              "error-container": "#ffdad6",
              "outline-variant": "#c1c6d7",
              "inverse-on-surface": "#f0f0f2",
              "surface-container-high": "#e8e8ea",
              "tertiary-container": "#008733",
              "inverse-surface": "#2f3132",
              "on-secondary-container": "#626267",
              "surface-container-low": "#f3f3f5",
              "on-primary-fixed-variant": "#004493",
              "on-error": "#ffffff",
              "on-surface-variant": "#414755",
              "tertiary-fixed-dim": "#53e16f",
              "surface": "#f9f9fb",
              "inverse-primary": "#adc6ff",
              "background": "#f9f9fb",
              "secondary-container": "#e0dfe4",
              "on-secondary-fixed-variant": "#46464b",
              "on-tertiary-fixed": "#002107",
              "primary-fixed": "#d8e2ff",
              "tertiary": "#006b27",
              "on-tertiary-container": "#f7fff2",
              "primary-fixed-dim": "#adc6ff",
              "on-background": "#1a1c1d"
            },
            fontFamily: {
              "headline": ["Be Vietnam Pro"],
              "body": ["Inter"],
              "label": ["Inter"]
            },
            borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
          },
        },
      }
    </script>
<style>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
      .tonal-transition { transition: background-color 0.3s ease; }
      body { -webkit-font-smoothing: antialiased; }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-surface font-body text-on-surface selection:bg-primary/10">
<!-- TopAppBar -->
<header class="fixed top-0 w-full z-50 bg-white/70 backdrop-blur-xl tonal-transition shadow-[0_20px_40px_rgba(0,0,0,0.04)]">
<div class="flex justify-between items-center px-6 py-4 w-full">
<div class="flex items-center gap-3">
<div class="w-10 h-10 rounded-full overflow-hidden ring-2 ring-primary/10">
<img alt="Ảnh đại diện người dùng" class="w-full h-full object-cover" data-alt="Professional headshot of a smiling Vietnamese man with short hair in a bright modern office setting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAIBAvVDnE39qLyNHqiFuUEy8B-Iq6wCIoZNlK7ZCbL2JjbGxIbFdSQAUcc7me0EGAzPXg4Ra6s6tSjzi-ke-xyIZeOXoANFugo2aCnXCPeMxmUu1V-nU-G8WnxvuHblu1nsoAmPmse6dAB5LnjcwDpOJkBfL3tgy97ch1H8F7iqfd1q_dvTVYAUgo9Nz2oB8AzGYSLuUOdFTOtWL06AAYeLm_esYkfmDZLzDjlyL0i0ZnAZdG7kwDKLtRfhd3HrIreWfDrjpeWpk5j"/>
</div>
<h1 class="font-headline font-bold text-2xl tracking-tight text-zinc-900">Chấm công</h1>
</div>
<button class="bg-primary-container text-on-primary-container px-4 py-2 rounded-full font-medium active:scale-95 duration-200 transition-opacity hover:opacity-80 flex items-center gap-2">
<span class="material-symbols-outlined text-[20px]" data-icon="add">add</span>
<span class="font-headline tracking-tight">+ Thêm mới</span>
</button>
</div>
</header>
<main class="pt-24 pb-32 px-6 max-w-2xl mx-auto space-y-8">
<!-- Current Status & FaceID Action -->
<section class="relative overflow-hidden bg-surface-container-lowest rounded-[40px] p-8 shadow-[0_20px_40px_rgba(0,0,0,0.04)]">
<div class="flex flex-col items-center text-center space-y-6">
<div class="space-y-1">
<p class="text-secondary font-medium label-sm tracking-wider uppercase">Trạng thái hiện tại</p>
<div class="flex items-center justify-center gap-2">
<span class="w-2.5 h-2.5 rounded-full bg-error animate-pulse"></span>
<h2 class="text-2xl font-headline font-bold text-on-surface">Chưa chấm công</h2>
</div>
</div>
<!-- Apple FaceID Style Button -->
<button class="group relative w-48 h-48 flex flex-col items-center justify-center gap-4 rounded-[48px] bg-gradient-to-br from-primary to-primary-container text-white shadow-2xl active:scale-95 transition-all duration-300">
<div class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity rounded-[48px]"></div>
<span class="material-symbols-outlined text-[72px] font-light" data-icon="faceid" style="font-variation-settings: 'wght' 200;">face</span>
<span class="font-headline font-semibold text-sm px-4">Chấm công khuôn mặt</span>
</button>
<p class="text-on-surface-variant text-sm max-w-[240px]">Vui lòng đảm bảo khuôn mặt nằm trong khung hình và đủ ánh sáng</p>
</div>
</section>
<!-- Location Verification (Mini Map) -->
<section class="space-y-4">
<div class="flex justify-between items-end px-2">
<h3 class="font-headline font-bold text-xl text-on-surface">Vị trí hiện tại</h3>
<span class="text-primary text-sm font-medium">Cập nhật lúc 08:30</span>
</div>
<div class="relative h-48 w-full rounded-[32px] overflow-hidden bg-surface-container shadow-sm">
<img alt="Bản đồ xác thực" class="w-full h-full object-cover grayscale brightness-95 contrast-75" data-alt="Modern minimalist city map interface with a blue glowing pulse dot marking current location in a metropolitan area" data-location="Ho Chi Minh City" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA4-yLnyJy-vNOBHxPot6-g8zHFB0FWIx2yo9qi8QZwcAbOLirimFSWV4T38Z8uuCO5zVRmamUoJPiidkxaGb02nTYLZAleV-3t5QLLUVIzrScqOjkxQBa0OgVomiC7rv2WP1HvCaXs_tpzhU3EvqEM_XCoRbIIDcBRXT_CClEgyHxUOB0UVo8F5X5lCeAV1YSDCtQfq0I9xLJ7s4u-eTcVXcpy5-xUS67Zp59N-UdNCcPMBtoun-K6EDtvXBbMxq7iCmg4VDY0pJl5"/>
<div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
<div class="absolute bottom-4 left-4 right-4 bg-white/90 backdrop-blur-md rounded-2xl p-4 flex items-center gap-3">
<div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
<span class="material-symbols-outlined text-primary" data-icon="location_on" style="font-variation-settings: 'FILL' 1;">location_on</span>
</div>
<div>
<p class="text-sm font-bold text-on-surface leading-tight">Tòa nhà Atelier</p>
<p class="text-xs text-secondary">Quận 1, TP. Hồ Chí Minh</p>
</div>
</div>
</div>
</section>
<!-- Weekly History Log -->
<section class="space-y-4">
<div class="flex justify-between items-end px-2">
<h3 class="font-headline font-bold text-xl text-on-surface">Lịch sử tuần này</h3>
<button class="text-secondary hover:text-primary transition-colors">
<span class="material-symbols-outlined" data-icon="calendar_month">calendar_month</span>
</button>
</div>
<div class="bg-surface-container-low rounded-[32px] p-2 space-y-1">
<!-- Log Item: Monday -->
<div class="flex items-center justify-between p-5 bg-white rounded-[24px] shadow-sm">
<div class="flex items-center gap-4">
<div class="w-12 h-12 rounded-2xl bg-zinc-50 flex flex-col items-center justify-center leading-none">
<span class="text-[10px] font-bold text-secondary">T2</span>
<span class="text-lg font-bold text-on-surface">12</span>
</div>
<div>
<p class="text-sm font-bold text-on-surface">Thứ Hai</p>
<p class="text-xs text-tertiary font-medium">Hoàn thành</p>
</div>
</div>
<div class="text-right">
<p class="text-sm font-bold text-on-surface">08:02 - 17:35</p>
<p class="text-[11px] text-secondary">8h 33m làm việc</p>
</div>
</div>
<!-- Log Item: Tuesday -->
<div class="flex items-center justify-between p-5 hover:bg-white/50 transition-colors rounded-[24px]">
<div class="flex items-center gap-4">
<div class="w-12 h-12 rounded-2xl bg-zinc-100/50 flex flex-col items-center justify-center leading-none">
<span class="text-[10px] font-bold text-secondary">T3</span>
<span class="text-lg font-bold text-on-surface">13</span>
</div>
<div>
<p class="text-sm font-bold text-on-surface">Thứ Ba</p>
<p class="text-xs text-tertiary font-medium">Hoàn thành</p>
</div>
</div>
<div class="text-right">
<p class="text-sm font-bold text-on-surface">07:58 - 18:10</p>
<p class="text-[11px] text-secondary">9h 12m làm việc</p>
</div>
</div>
<!-- Log Item: Wednesday (Today) -->
<div class="flex items-center justify-between p-5 hover:bg-white/50 transition-colors rounded-[24px]">
<div class="flex items-center gap-4">
<div class="w-12 h-12 rounded-2xl bg-zinc-100/50 flex flex-col items-center justify-center leading-none">
<span class="text-[10px] font-bold text-secondary">T4</span>
<span class="text-lg font-bold text-on-surface">14</span>
</div>
<div>
<p class="text-sm font-bold text-on-surface">Thứ Tư (Hôm nay)</p>
<p class="text-xs text-error font-medium">Chưa có dữ liệu</p>
</div>
</div>
<div class="text-right">
<p class="text-sm font-bold text-secondary">-- : --</p>
<p class="text-[11px] text-zinc-400">Đang chờ</p>
</div>
</div>
</div>
</section>
</main>

<!-- BottomNavBar -->
<nav class="fixed bottom-0 w-full z-50 rounded-t-[32px] bg-white/80 backdrop-blur-2xl shadow-2xl no-border">
<div class="flex justify-around items-center px-4 py-3 pb-8 w-full">
<a class="flex flex-col items-center justify-center text-zinc-400 p-2 hover:text-blue-500 transition-transform active:scale-90" href="#">
<span class="material-symbols-outlined" data-icon="dashboard">dashboard</span>
<span class="font-['Inter'] text-[11px] font-medium tracking-wide">Tổng quan</span>
</a>
<a class="flex flex-col items-center justify-center text-zinc-400 p-2 hover:text-blue-500 transition-transform active:scale-90" href="#">
<span class="material-symbols-outlined" data-icon="group">group</span>
<span class="font-['Inter'] text-[11px] font-medium tracking-wide">Nhân viên</span>
</a>
<a class="flex flex-col items-center justify-center text-blue-600 bg-blue-50/50 rounded-2xl p-2 transition-transform active:scale-90" href="#">
<span class="material-symbols-outlined" data-icon="fact_check" style="font-variation-settings: 'FILL' 1;">fact_check</span>
<span class="font-['Inter'] text-[11px] font-medium tracking-wide">Chấm công</span>
</a>
<a class="flex flex-col items-center justify-center text-zinc-400 p-2 hover:text-blue-500 transition-transform active:scale-90" href="#">
<span class="material-symbols-outlined" data-icon="forum">forum</span>
<span class="font-['Inter'] text-[11px] font-medium tracking-wide">Chat</span>
</a>
<a class="flex flex-col items-center justify-center text-zinc-400 p-2 hover:text-blue-500 transition-transform active:scale-90" href="#">
<span class="material-symbols-outlined" data-icon="settings">settings</span>
<span class="font-['Inter'] text-[11px] font-medium tracking-wide">Cài đặt</span>
</a>
</div>
</nav>
</body></html>