@{
    ViewData["Title"] = "Quản lý Đơn từ";
    ViewData["PageHeader"] = "Quản lý Đơn từ";
    
    // Ẩn nút AI chung của Layout để dùng nút AI riêng của trang này
    ViewData["HideFloatingAI"] = true;
}

<div class="flex gap-2 overflow-x-auto pb-4 no-scrollbar mb-8">
    <button class="px-6 py-2.5 rounded-full bg-primary text-white font-medium whitespace-nowrap shadow-lg shadow-primary/20">Tất cả</button>
    <button class="px-6 py-2.5 rounded-full bg-surface-container-low text-secondary font-medium whitespace-nowrap hover:bg-surface-container-high transition-colors">Chờ duyệt</button>
    <button class="px-6 py-2.5 rounded-full bg-surface-container-low text-secondary font-medium whitespace-nowrap hover:bg-surface-container-high transition-colors">Đã duyệt</button>
    <button class="px-6 py-2.5 rounded-full bg-surface-container-low text-secondary font-medium whitespace-nowrap hover:bg-surface-container-high transition-colors">Từ chối</button>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="bg-surface-container-lowest p-6 rounded-[32px] shadow-[0_20px_40px_rgba(0,0,0,0.04)] hover:shadow-[0_24px_48px_rgba(0,0,0,0.08)] transition-all group border border-transparent hover:border-primary/5">
        <div class="flex justify-between items-start mb-6">
            <div class="p-3 bg-blue-50 rounded-2xl text-primary">
                <span class="material-symbols-outlined text-[28px]">event_busy</span>
            </div>
            <span class="px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider bg-amber-50 text-amber-700">Chờ duyệt</span>
        </div>
        <h3 class="font-headline font-bold text-xl mb-1">Đơn nghỉ phép</h3>
        <p class="text-secondary text-sm mb-6">Nghỉ phép năm • 2 ngày (14/10 - 15/10)</p>
        <div class="flex items-center gap-3 pt-6 border-t border-surface-container">
            <img alt="Lê Thị Mai" class="w-8 h-8 rounded-full object-cover" src="~/images/avatar_mai.jpg" />
            <div class="flex-1">
                <p class="text-xs font-semibold text-on-surface">Lê Thị Mai</p>
                <p class="text-[10px] text-outline">Phòng Marketing</p>
            </div>
            <span class="material-symbols-outlined text-outline group-hover:text-primary transition-colors">arrow_forward_ios</span>
        </div>
    </div>

    <div class="bg-surface-container-lowest p-6 rounded-[32px] shadow-[0_20px_40px_rgba(0,0,0,0.04)] hover:shadow-[0_24px_48px_rgba(0,0,0,0.08)] transition-all group border border-transparent hover:border-primary/5">
        <div class="flex justify-between items-start mb-6">
            <div class="p-3 bg-emerald-50 rounded-2xl text-emerald-600">
                <span class="material-symbols-outlined text-[28px]">flight_takeoff</span>
            </div>
            <span class="px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider bg-emerald-50 text-emerald-700">Đã duyệt</span>
        </div>
        <h3 class="font-headline font-bold text-xl mb-1">Đơn công tác</h3>
        <p class="text-secondary text-sm mb-6">Công tác Hà Nội • 5 ngày (20/10 - 25/10)</p>
        <div class="flex items-center gap-3 pt-6 border-t border-surface-container">
            <img alt="Trần Minh Tâm" class="w-8 h-8 rounded-full object-cover" src="~/images/avatar_tam.jpg" />
            <div class="flex-1">
                <p class="text-xs font-semibold text-on-surface">Trần Minh Tâm</p>
                <p class="text-[10px] text-outline">Phòng Kinh doanh</p>
            </div>
            <span class="material-symbols-outlined text-outline group-hover:text-primary transition-colors">arrow_forward_ios</span>
        </div>
    </div>

    <div class="bg-surface-container-low border-2 border-dashed border-outline-variant p-6 rounded-[32px] flex flex-col items-center justify-center text-center opacity-60 hover:opacity-100 transition-opacity cursor-pointer">
        <div class="w-14 h-14 rounded-full bg-white flex items-center justify-center mb-4 shadow-sm">
            <span class="material-symbols-outlined text-primary text-[32px]">add_circle</span>
        </div>
        <h3 class="font-headline font-bold text-lg">Tạo đơn mới</h3>
        <p class="text-secondary text-xs max-w-[200px] mt-1">Gửi yêu cầu phê duyệt nhanh chóng và minh bạch</p>
    </div>
</div>

<div class="fixed bottom-28 left-6 z-40 group">
    <div class="bg-white p-4 rounded-3xl shadow-xl flex items-center gap-3 border border-primary/5 cursor-pointer hover:bg-primary-container hover:text-white transition-all">
        <span class="material-symbols-outlined text-primary group-hover:text-white">smart_toy</span>
        <span class="text-sm font-medium pr-2">Hỏi Trợ lý AI</span>
    </div>
</div>

<button class="fixed right-6 bottom-32 w-14 h-14 bg-primary text-white rounded-2xl shadow-2xl flex items-center justify-center hover:scale-105 active:scale-95 transition-transform z-40">
    <span class="material-symbols-outlined text-[28px]">add</span>
</button>