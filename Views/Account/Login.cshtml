@{
    Layout = null; // Vô hiệu hóa layout chung để trang đăng nhập đứng độc lập
}

<!DOCTYPE html>
<html class="light" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Đăng nhập | HR Atelier</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <script id="tailwind-config">
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
        colors: {
        "outline": "#717786",
        "primary": "#0058bc",
        "surface-tint": "#005bc1",
        "surface-container": "#eeeef0",
        "on-error-container": "#93000a",
        "surface-dim": "#d9dadc",
        "secondary-fixed-dim": "#c7c6cb",
        "primary-container": "#0070eb",
        "secondary-fixed": "#e3e2e7",
        "on-secondary": "#ffffff",
        "on-primary-fixed": "#001a41",
        "on-primary": "#ffffff",
        "surface-container-lowest": "#ffffff",
        "error": "#ba1a1a",
        "on-tertiary": "#ffffff",
        "on-primary-container": "#fefcff",
        "on-surface": "#1a1c1d",
        "on-tertiary-fixed-variant": "#00531c",
        "surface-container-highest": "#e2e2e4",
        "secondary": "#5e5e63",
        "surface-bright": "#f9f9fb",
        "surface-variant": "#e2e2e4",
        "on-secondary-fixed": "#1a1b1f",
        "tertiary-fixed": "#72fe88",
        "error-container": "#ffdad6",
        "outline-variant": "#c1c6d7",
        "inverse-on-surface": "#f0f0f2",
        "surface-container-high": "#e8e8ea",
        "tertiary-container": "#008733",
        "inverse-surface": "#2f3132",
        "on-secondary-container": "#626267",
        "surface-container-low": "#f3f3f5",
        "on-primary-fixed-variant": "#004493",
        "on-error": "#ffffff",
        "on-surface-variant": "#414755",
        "tertiary-fixed-dim": "#53e16f",
        "surface": "#f9f9fb",
        "inverse-primary": "#adc6ff",
        "background": "#f9f9fb",
        "secondary-container": "#e0dfe4",
        "on-secondary-fixed-variant": "#46464b",
        "on-tertiary-fixed": "#002107",
        "primary-fixed": "#d8e2ff",
        "tertiary": "#006b27",
        "on-tertiary-container": "#f7fff2",
        "primary-fixed-dim": "#adc6ff",
        "on-background": "#1a1c1d"
        },
        fontFamily: {
        "headline": ["Be Vietnam Pro"],
        "body": ["Inter"],
        "label": ["Inter"]
        },
        borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
        },
        },
        }
    </script>
    <style>
        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .tonal-transition {
        background: linear-gradient(180deg, rgba(255,255,255,0) 0%, #f3f3f5 100%);
        }

        .apple-toggle:checked + .toggle-track {
        background-color: #0058bc;
        }

        .apple-toggle:checked + .toggle-track .toggle-thumb {
        transform: translateX(1.25rem);
        }

        body {
        min-height: max(884px, 100dvh);
        }
    </style>
</head>
<body class="bg-surface font-body text-on-surface selection:bg-primary-fixed selection:text-on-primary-fixed min-h-screen flex items-center justify-center p-6">
    <main class="w-full max-w-[440px] flex flex-col items-center">
        <header class="mb-14 text-center">
            <div class="mb-6 flex justify-center">
                <div class="w-16 h-16 bg-primary-container rounded-[22px] flex items-center justify-center shadow-lg transform rotate-3">
                    <span class="material-symbols-outlined text-white text-4xl" style="font-variation-settings: 'FILL' 1;">work</span>
                </div>
            </div>
            <h1 class="font-headline font-extrabold text-3xl tracking-tight text-on-surface mb-2">HR Atelier</h1>
            <p class="text-secondary font-medium tracking-tight">Hệ thống quản trị nhân sự cao cấp</p>
        </header>

        <div class="w-full bg-surface-container-lowest rounded-[32px] p-8 md:p-10 shadow-[0_20px_40px_rgba(0,0,0,0.04),0_1px_3px_rgba(0,0,0,0.02)]">
            <div class="mb-8">
                <h2 class="font-headline font-bold text-2xl text-on-surface">Chào mừng trở lại</h2>
                <p class="text-on-surface-variant text-sm mt-1">Đăng nhập để quản lý công việc của bạn</p>
            </div>

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="bg-error-container text-on-error-container text-sm p-4 rounded-2xl mb-6 text-center font-medium border border-error/20">
                    @ViewBag.ErrorMessage
                </div>
            }

            <form asp-controller="Account" asp-action="Login" method="post" class="space-y-6">
                <div class="space-y-2">
                    <label class="block text-[11px] font-semibold text-secondary px-1 uppercase tracking-wider" for="email">Email công ty</label>
                    <div class="relative group">
                        <input name="email" class="w-full px-5 py-4 bg-surface-container-low border-0 rounded-2xl focus:ring-4 focus:ring-primary/10 transition-all text-on-surface placeholder:text-outline/50" id="email" placeholder="name@atelier.com" type="email" required />
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 text-tertiary opacity-0 group-focus-within:opacity-100 transition-opacity">
                            <span class="material-symbols-outlined text-xl">check_circle</span>
                        </div>
                    </div>
                </div>

                <div class="space-y-2">
                    <div class="flex justify-between items-center px-1">
                        <label class="block text-[11px] font-semibold text-secondary uppercase tracking-wider" for="password">Mật khẩu</label>
                        <a class="text-[11px] font-bold text-primary hover:opacity-70 transition-opacity" href="#">Quên mật khẩu?</a>
                    </div>
                    <div class="relative">
                        <input name="password" class="w-full px-5 py-4 bg-surface-container-low border-2 border-transparent focus:border-transparent focus:ring-4 focus:ring-primary/10 rounded-2xl transition-all text-on-surface" id="password" type="password" placeholder="Nhập mật khẩu" required />
                        <button class="absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-on-surface transition-colors" type="button">
                            <span class="material-symbols-outlined text-xl">visibility_off</span>
                        </button>
                    </div>
                </div>

                <div class="flex items-center justify-between py-2">
                    <span class="text-sm font-medium text-on-surface-variant">Ghi nhớ đăng nhập</span>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input checked="" class="sr-only peer apple-toggle" type="checkbox" name="rememberMe" value="true" />
                        <div class="toggle-track w-11 h-6 bg-surface-container-highest peer-focus:outline-none rounded-full transition-colors duration-200">
                            <div class="toggle-thumb absolute top-[2px] left-[2px] bg-white border-zinc-200 border rounded-full h-5 w-5 transition-transform duration-200 shadow-sm"></div>
                        </div>
                    </label>
                </div>

                <button class="w-full py-4 px-6 bg-gradient-to-br from-primary to-primary-container text-white font-semibold rounded-2xl shadow-lg hover:shadow-primary/20 active:scale-[0.98] transition-all duration-200 flex items-center justify-center gap-2" type="submit">
                    Đăng nhập
                    <span class="material-symbols-outlined text-lg">arrow_forward</span>
                </button>
            </form>

            <div class="mt-8">
                <div class="relative mb-6">
                    <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-surface-container-high"></div></div>
                    <div class="relative flex justify-center text-[10px] uppercase tracking-[0.2em] font-bold text-secondary-fixed-dim">
                        <span class="bg-surface-container-lowest px-4">Hoặc tiếp tục với</span>
                    </div>
                </div>
                <div class="grid gap-4 flex justify-center">
                    <button class="flex items-center justify-center gap-2 py-3 px-4 bg-surface-container-low rounded-xl hover:bg-surface-container-high transition-colors w-full max-w-[200px]" type="button">
                        <img alt="Google" class="w-5 h-5 object-contain" src="~/images/google_logo.png" />
                        <span class="text-sm font-semibold text-on-surface">Google</span>
                    </button>
                </div>
            </div>
        </div>

        <footer class="mt-12 text-center">
            <p class="text-secondary text-[11px] leading-relaxed">
                Bằng cách đăng nhập, bạn đồng ý với <br />
                <a class="text-on-surface font-bold hover:underline" href="#">Điều khoản Dịch vụ</a> & <a class="text-on-surface font-bold hover:underline" href="#">Chính sách Bảo mật</a>
            </p>
        </footer>
    </main>

    <div class="fixed top-0 left-0 w-full h-full pointer-events-none -z-10 overflow-hidden">
        <div class="absolute -top-[20%] -right-[10%] w-[60%] h-[60%] rounded-full bg-primary/5 blur-[120px]"></div>
        <div class="absolute top-[60%] -left-[10%] w-[40%] h-[40%] rounded-full bg-tertiary/5 blur-[100px]"></div>
        <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(#0058bc 0.5px, transparent 0.5px); background-size: 24px 24px;"></div>
    </div>
</body>
</html>